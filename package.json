{
  "name": "doc-collab",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "tsx watch server.ts --dev",
    "dev:mcp": "tsx watch mcp-server/server.ts",
    "dev:all": "concurrently -n web,mcp -c blue,magenta \"npm:dev\" \"npm:dev:mcp\"",
    "build": "next build && npm run build:server && npm run build:mcp && npm run build:collab",
    "build:server": "tsc -p tsconfig.server.json",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "build:collab": "tsc --outDir dist src/collab-server.ts",
    "start": "NODE_ENV=production node dist/server.js",
    "start:mcp": "NODE_ENV=production node dist/mcp-server/mcp-server/server.js",
    "start:collab": "NODE_ENV=production node dist/collab-server.js",
    "dev:collab": "tsx watch src/collab-server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "cypress": "cypress run --headed false",
    "cypress:collab": "cypress run --spec cypress/e2e/collaboration.cy.ts",
    "cypress:open": "cypress open"
  },
  "dependencies": {
    "@hocuspocus/provider": "^4.2.0",
    "@hocuspocus/server": "^4.2.0",
    "@hocuspocus/transformer": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tiptap/extension-code-block-lowlight": "^3.26.1",
    "@tiptap/extension-collaboration": "^3.26.1",
    "@tiptap/extension-collaboration-caret": "^3.26.1",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-table-cell": "^3.26.1",
    "@tiptap/extension-table-header": "^3.26.1",
    "@tiptap/extension-table-row": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "chokidar": "^5.0.0",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.17.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tiptap-markdown": "^0.9.0",
    "unified": "^11.0.5",
    "ws": "^8.21.0",
    "y-indexeddb": "^9.0.12",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "cypress": "^15.17.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
