# Document storage directory
# Change to point to a different location for your documents
# DOCUMENTS_DIR=/path/to/documents

# Server bind address (default: local-only)
# WSL2 IP when browsing from Windows — enables dev HMR (see hostname -I)
# ALLOWED_DEV_ORIGINS=172.17.18.206

# Server port (default: 3000)
# PORT=3000

# WebSocket authentication token (auto-generated if not set)
# WS_TOKEN=your-secret-token-here

# Phase 2 CRDT collaboration in the editor (default: on). Set to 0 for Phase 1 REST editing.
# NEXT_PUBLIC_COLLAB=0

# MCP agent uses Hocuspocus CRDT peer for reads/writes (default: on)
# Set to 0 to force filesystem-only MCP tools (tests / offline)
# MCP_COLLAB=1

# Use Webpack instead of Turbopack for `npm run dev` (if Turbopack hangs/crashes)
# DEV_WEBPACK=1
