# Document storage directory
# Change to point to a different location for your documents
# DOCUMENTS_DIR=/path/to/documents

# Server bind address (default: local-only)
# HOST=127.0.0.1

# Server port (default: 3000)
# PORT=3000

# WebSocket authentication token (auto-generated if not set)
# WS_TOKEN=your-secret-token-here

# Enable Phase 2 CRDT collaboration in the editor (default: off)
# NEXT_PUBLIC_COLLAB=1
