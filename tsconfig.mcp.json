{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./dist/mcp-server",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["mcp-server/**/*.ts", "src/lib/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/lib/pdf.tsx"],
  "references": []
}
